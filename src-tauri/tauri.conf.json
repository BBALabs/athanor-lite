{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Athanor",
    "version":  "0.1.1",
    "identifier":  "com.bba.athanor",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Athanor",
                                    "width":  1440,
                                    "height":  900,
                                    "minWidth":  1100,
                                    "minHeight":  720,
                                    "center":  true,
                                    "decorations":  false,
                                    "backgroundColor":  "#0a0612"
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; script-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; img-src \u0027self\u0027 data:; font-src \u0027self\u0027 data:; connect-src ipc: http://ipc.localhost"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "createUpdaterArtifacts":  true
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGMTlDOEU3RUI3REQwOEUKUldTTzBIM3I1OGdaWDBETXh4UGRrc0lOYklSV0FiUzNHUnN5ZG5aNHVaY2FJbTNRNWpFZ0lqTnoK",
                                    "endpoints":  [
                                                      "https://releases.bbasecure.com/athanor/latest.json"
                                                  ]
                                }
                }
}